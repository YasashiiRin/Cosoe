{
  "manifest_version": 3,
  "name": "Console Chat",
  "version": "1.0",
  "description": "Console cho Zalo và Messenger",

  "permissions": ["storage"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "128": "images/inferno128.png"
    }
  },

  "icons": {
    "128": "images/inferno128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["scripts/content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}